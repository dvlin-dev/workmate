{
  "name": "workmate",
  "version": "0.1.1",
  "description": "Workmate · 工作搭子 — AI-native macOS work buddy",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "electron-vite build && electron-builder --dir",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:mac:x64": "electron-vite build && electron-builder --mac dmg zip --x64 --publish never",
    "smoke:packaged": "node scripts/smoke-check-packaged-app.mjs --app-dir release/${npm_package_version} --require-package @openai/agents --require-package @openai/agents-core --require-package @openai/agents-extensions --require-package ai --require-package electron-store"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.30",
    "@openai/agents": "0.4.3",
    "@openai/agents-core": "0.5.1",
    "@openai/agents-extensions": "0.5.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "ai": "6.0.97",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.553.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "4.3.6",
    "zustand": "^5.0.2"
  },
  "pnpm": {
    "overrides": {
      "@openai/agents": "0.4.3",
      "@openai/agents-core": "0.5.1",
      "@openai/agents-openai": "0.4.3",
      "@openai/agents-realtime": "0.4.3"
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@electron/asar": "^3.4.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "electron": "31.7.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.2.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "vite": "^5.4.20",
    "vitest": "^2.1.8"
  }
}
