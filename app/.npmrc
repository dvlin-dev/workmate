# 对齐 moryflow：扁平 node_modules（与 npm 一致），electron-vite / electron-builder 正常解析依赖
node-linker=hoisted
auto-install-peers=true
# 允许这些依赖运行构建脚本（否则 electron 二进制不下载、原生 swc/esbuild 缺失）
onlyBuiltDependencies=electron,esbuild,@swc/core
# 关闭副作用缓存：避免 pnpm 把 electron 的 postinstall 结果残缺地还原（缺 path.txt/version → "Electron uninstall"）
side-effects-cache=false
